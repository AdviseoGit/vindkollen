      "mainEntity": [
        {
          "@type": "Question",
          "name": "Vad är 'bygdepeng'?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Det är en frivillig ersättning som vindkraftsbolag betalar till lokalsamhället för att kompensera för störningar och skapa lokal nytta."
          }
        },
        {
          "@type": "Question",
          "name": "Är ersättningen skattepliktig?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Markarrende och royalty beskattas normalt som kapitalinkomst. Den nya närboendeersättningen som införs 1 juli 2026 är dock skattefri till den del den avser en privatbostad."
          }
        },
        {
          "@type": "Question",
          "name": "Hur länge gäller ett avtal?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ett anläggningsarrende för vindkraft löper vanligtvis under hela vindkraftverkets tekniska livslängd – 25–30 år, och i vissa fall upp till 50 år."
          }
        },
        {
          "@type": "Question",
          "name": "Kan jag förhandla om ersättningen?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja, de frivilliga ersättningarna är alltid en förhandlingsfråga. Ta gärna hjälp av juridisk eller teknisk expertis för att säkra ett rättvist avtal."
          }
        }
      ]
    }
